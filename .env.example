# Copy this file to .env.local and fill in the values.
# Never commit .env or .env.local — they contain secrets.

# ============================================================
# Application
# ============================================================
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
LOG_LEVEL=debug

# ============================================================
# Database (Supabase Postgres)
# ============================================================
# Pooler connection string used by the app at runtime.
DATABASE_URL=postgresql://postgres:password@host:6543/postgres?pgbouncer=true&connection_limit=1
# Direct connection used by Prisma migrate / introspection.
DIRECT_URL=postgresql://postgres:password@host:5432/postgres

# ============================================================
# Supabase (Storage + client)
# ============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ============================================================
# Auth.js v5
# ============================================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-strong-random-secret
AUTH_URL=http://localhost:3000

# ============================================================
# Database seed (npm run db:seed)
# ============================================================
# Used by prisma/seed.ts to create the first admin user.
# Rotate this password immediately after first login in production.
SEED_ADMIN_EMAIL=admin@diaryasmine.tn
SEED_ADMIN_PASSWORD=changeMe1234!

# ============================================================
# Email (Resend) + React Email
# ============================================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Diar Yasmine <noreply@mail.diaryasmine.tn>
RESEND_REPLY_TO=contact@diaryasmine.tn

# ============================================================
# SMS / WhatsApp (Twilio)
# ============================================================
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+216XXXXXXXX
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ============================================================
# Payments
# ============================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Future Tunisia gateways
FLOUCI_APP_TOKEN=
FLOUCI_APP_SECRET=
KONNECT_API_KEY=
KONNECT_RECEIVER_WALLET_ID=

# ============================================================
# Observability
# ============================================================
SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ============================================================
# Rate limiting (Upstash Redis)
# ============================================================
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ============================================================
# Public contact (visible in browser)
# ============================================================
NEXT_PUBLIC_WHATSAPP_NUMBER=+216XXXXXXXX
NEXT_PUBLIC_CONTACT_EMAIL=contact@diaryasmine.tn
