// Prisma schema for Diar Yasmine.
//
// Design notes:
// - Money is stored as Int in millimes (1 TND = 1000 millimes). Never Float.
// - Dates are timestamptz UTC. Business logic uses Africa/Tunis (see /lib/date.ts).
// - Soft delete via `deletedAt` on Property, Reservation, Guest.
// - Double-booking prevention: EXCLUDE GIST constraint on Reservation
//   (added in a follow-up SQL migration, see prisma/migrations/*).
// - Settings live in a single Setting table with a typed registry
//   (see /lib/settings/registry.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  ADMIN
  MANAGER
  RECEPTION
  VIEWER
}

enum PropertyType {
  CHALET
  BUNGALOW
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum PhotoCategory {
  GENERAL
  EXTERIOR
  INTERIOR
  BEDROOM
  BATHROOM
  KITCHEN
  POOL
  VIEW
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum ReservationSource {
  DIRECT_WEB
  WALK_IN
  PHONE
  PARTNER
  BOOKING
  AIRBNB
  EXPEDIA
  OTHER
}

enum DiscountType {
  NONE
  PERCENT
  FIXED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  STRIPE
  FLOUCI
  KONNECT
  OTHER
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum ChannelType {
  BOOKING
  AIRBNB
  EXPEDIA
  OTHER
}

enum ChannelSyncStatus {
  IDLE
  SYNCING
  ERROR
}

// =============================================================================
// STAFF (User) — internal users only, never linked to reservations directly
// =============================================================================

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String
  hashedPassword String
  role           UserRole  @default(VIEWER)
  image          String?
  lastLoginAt    DateTime? @db.Timestamptz(3)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  createdReservations Reservation[]   @relation("CreatedBy")
  receivedPayments    Payment[]       @relation("ReceivedBy")
  auditLogs           AuditLog[]
  settingsUpdated     Setting[]
  moderatedReviews    Review[]        @relation("ReviewModeratedBy")
  notesAuthored       InternalNote[]
  documentsUploaded   GuestDocument[]
  promoCodesCreated   PromoCode[]

  @@index([role])
}

// =============================================================================
// CUSTOMERS (Guest) — passive by default, upgradeable to a full account
// =============================================================================

model Guest {
  id         String  @id @default(cuid())
  firstName  String
  lastName   String
  phone      String  @unique
  email      String? @unique
  whatsapp   String?
  country    String?
  idDocument String?
  notes      String?

  /// Flagged VIP — surfaced as a badge on the reservation calendar and
  /// the reservation detail. Used to fast-track service.
  isVip Boolean @default(false)

  /// Free-form admin tags (e.g. "Allergie chat", "Famille fidèle",
  /// "Anniversaire en mai"). Indexed for fuzzy admin search.
  tags String[] @default([])

  // Auth fields — all null until the guest creates an account.
  // The upgrade flow uses OTP SMS on the registered phone (see CLAUDE.md).
  hashedPassword   String?
  emailVerifiedAt  DateTime? @db.Timestamptz(3)
  phoneVerifiedAt  DateTime? @db.Timestamptz(3)
  accountCreatedAt DateTime? @db.Timestamptz(3)
  lastLoginAt      DateTime? @db.Timestamptz(3)

  createdAt DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @db.Timestamptz(3)
  deletedAt DateTime? @db.Timestamptz(3)

  reservations  Reservation[]
  reviews       Review[]
  documents     GuestDocument[]
  internalNotes InternalNote[]

  @@index([phone])
  @@index([email])
  @@index([accountCreatedAt])
  @@index([deletedAt])
  @@index([isVip])
}

// =============================================================================
// PROPERTIES — 9 chalets + 12 bungalows
// =============================================================================

model Property {
  id     String         @id @default(cuid())
  slug   String         @unique
  name   String
  type   PropertyType
  status PropertyStatus @default(ACTIVE)

  capacity       Int // max guests
  bedrooms       Int
  bathrooms      Int
  hasPrivatePool Boolean @default(false)
  seaView        Boolean @default(false)
  beachfront     Boolean @default(false)
  sizeM2         Int?

  descriptionFr String  @db.Text
  descriptionEn String? @db.Text
  descriptionAr String? @db.Text

  basePrice   Int @default(0) // millimes per night
  cleaningFee Int @default(0) // millimes
  minStay     Int @default(1) // nights

  createdAt DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @db.Timestamptz(3)
  deletedAt DateTime? @db.Timestamptz(3)

  photos       Photo[]
  amenities    PropertyAmenity[]
  priceRules   PriceRule[]
  reservations Reservation[]
  channelSyncs ChannelSync[]
  reviews      Review[]

  @@index([type, status])
  @@index([deletedAt])
}

model Photo {
  id         String        @id @default(cuid())
  propertyId String
  url        String
  alt        String?
  order      Int           @default(0)
  category   PhotoCategory @default(GENERAL)
  createdAt  DateTime      @default(now()) @db.Timestamptz(3)

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, order])
}

model Amenity {
  id         String  @id @default(cuid())
  slug       String  @unique
  labelFr    String
  labelEn    String?
  labelAr    String?
  icon       String? // lucide icon name
  category   String?
  /**
   * Display this amenity as a quick-filter in the public listing sidebar.
   * Off by default — only headline amenities (Wi-Fi, BBQ, etc.) should be
   * surfaced as filters. Managed from /admin/amenities.
   */
  filterable Boolean @default(false)
  /**
   * Sort order for the admin catalog and the filter sidebar. Lower first.
   */
  sortOrder  Int     @default(100)

  properties PropertyAmenity[]

  @@index([filterable, sortOrder])
}

model PropertyAmenity {
  propertyId String
  amenityId  String

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity  Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([propertyId, amenityId])
  @@index([amenityId])
}

// =============================================================================
// PRICING — seasons and per-property price rules
// =============================================================================

model Season {
  id              String   @id @default(cuid())
  name            String
  startDate       DateTime @db.Date
  endDate         DateTime @db.Date
  // Basis points: 1000 = 1.000x, 1500 = 1.500x. Stored as Int to avoid Float arithmetic.
  priceMultiplier Int      @default(1000)

  priceRules PriceRule[]

  @@index([startDate, endDate])
}

model PriceRule {
  id           String   @id @default(cuid())
  propertyId   String
  seasonId     String?
  dateFrom     DateTime @db.Date
  dateTo       DateTime @db.Date
  nightlyPrice Int // millimes
  weekendPrice Int? // millimes
  weekMinStay  Int?

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  season   Season?  @relation(fields: [seasonId], references: [id], onDelete: SetNull)

  @@index([propertyId, dateFrom, dateTo])
}

// =============================================================================
// RESERVATIONS — core entity
// =============================================================================

model Reservation {
  id   String @id @default(cuid())
  code String @unique // human-readable: DY-YYYYMMDD-XXXX

  propertyId  String
  guestId     String
  createdById String?

  checkIn  DateTime @db.Timestamptz(3)
  checkOut DateTime @db.Timestamptz(3)
  nights   Int
  adults   Int
  children Int      @default(0)

  // Pricing breakdown (all millimes Int)
  basePrice      Int // sum of nightly prices before discount/extras
  discountType   DiscountType @default(NONE)
  discountValue  Int          @default(0) // raw % (0-100) or millimes
  discountAmount Int          @default(0) // computed millimes amount
  extras         Json         @default("[]") // [{ label, amount, category? }]
  extrasTotal    Int          @default(0)
  subtotal       Int // basePrice + extrasTotal - discountAmount
  tax            Int          @default(0)
  total          Int // subtotal + tax
  paidAmount     Int          @default(0)

  status     ReservationStatus @default(PENDING)
  source     ReservationSource
  externalId String? // OTA reservation ID (Booking, Airbnb, Expedia)

  voucherUrl    String?
  internalNotes String?
  guestRequests String?

  createdAt DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @db.Timestamptz(3)
  deletedAt DateTime? @db.Timestamptz(3)

  property            Property         @relation(fields: [propertyId], references: [id])
  guest               Guest            @relation(fields: [guestId], references: [id])
  createdBy           User?            @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  payments            Payment[]
  review              Review?
  internalNoteEntries InternalNote[]
  promoRedemption     PromoRedemption?

  @@index([propertyId, checkIn, checkOut])
  @@index([guestId])
  @@index([status, source])
  @@index([deletedAt])
  @@index([externalId])
  @@index([checkIn])
}

// =============================================================================
// PAYMENTS — multiple per reservation (deposit + balance, refunds, etc.)
// =============================================================================

model Payment {
  id            String        @id @default(cuid())
  reservationId String
  amount        Int // millimes
  method        PaymentMethod
  status        PaymentStatus @default(SUCCEEDED)
  receivedAt    DateTime      @default(now()) @db.Timestamptz(3)
  receivedById  String?
  reference     String? // Stripe payment intent id, OTA transaction ref, cash receipt #
  notes         String?

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  receivedBy  User?       @relation("ReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull)

  @@index([reservationId, status])
  @@index([receivedAt])
  @@index([method])
}

// =============================================================================
// CHANNEL MANAGER — iCal feeds per property × channel
// =============================================================================

model ChannelSync {
  id         String            @id @default(cuid())
  channel    ChannelType
  propertyId String
  url        String? // iCal feed URL
  lastSyncAt DateTime?         @db.Timestamptz(3)
  status     ChannelSyncStatus @default(IDLE)
  log        Json? // last sync error / stats

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([channel, propertyId])
  @@index([status])
}

// =============================================================================
// AUDIT LOG — required on every mutation of Reservation/Payment/Property/Guest
// =============================================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String // "reservation.created", "payment.received", "guest.merged", ...
  entity    String // "Reservation", "Payment", "Guest", "Property", "Setting"
  entityId  String
  diff      Json // { before: {...}, after: {...} } or { fields: [...] }
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now()) @db.Timestamptz(3)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([userId, timestamp])
  @@index([timestamp])
}

// =============================================================================
// CUSTOMER OTP — short-lived codes for the Guest → account upgrade flow
// =============================================================================

enum OtpPurpose {
  ACCOUNT_UPGRADE
  PHONE_VERIFY
  PASSWORD_RESET
}

model CustomerOtp {
  id         String     @id @default(cuid())
  /**
   * Bcrypt-hashed 6-digit code. Never stored in clear.
   */
  codeHash   String
  /**
   * E.164 phone the OTP was sent to. Indexed for lookup.
   */
  phone      String
  /**
   * Optional link to the existing Guest (set when upgrading a known guest).
   */
  guestId    String?
  purpose    OtpPurpose
  expiresAt  DateTime   @db.Timestamptz(3)
  consumedAt DateTime?  @db.Timestamptz(3)
  attempts   Int        @default(0)
  ipAddress  String?
  createdAt  DateTime   @default(now()) @db.Timestamptz(3)

  @@index([phone, purpose, expiresAt])
  @@index([guestId])
}

// =============================================================================
// SETTINGS — typed key/value store (registry-validated in /lib/settings)
// =============================================================================

model Setting {
  key         String   @id // registry key, e.g. "tax.rate", "voucher.terms_fr"
  value       Json
  updatedById String?
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  updatedBy User? @relation(fields: [updatedById], references: [id], onDelete: SetNull)
}

// =============================================================================
// REVIEWS — guest-submitted post-stay, admin-moderated, OTA imports
// =============================================================================

enum ReviewStatus {
  PENDING // submitted, awaiting admin moderation
  PUBLISHED // visible on the property fiche
  REJECTED // moderated out (spam, abusive, off-topic)
}

enum ReviewSource {
  DIRECT // public /review/[code] submission
  BOOKING
  AIRBNB
  EXPEDIA
  MANUAL // typed in by admin
}

model Review {
  id            String       @id @default(cuid())
  reservationId String?      @unique
  propertyId    String
  guestId       String?
  /// 1-5 stars (inclusive).
  rating        Int
  /// Optional free-text in the guest's locale.
  comment       String?      @db.Text
  /// FR/EN/AR — used to filter display on the property fiche.
  locale        String       @default("fr")
  source        ReviewSource @default(DIRECT)
  status        ReviewStatus @default(PENDING)
  /// Optional reply from the host shown beneath the review.
  hostReply     String?      @db.Text
  hostReplyAt   DateTime?    @db.Timestamptz(3)
  moderatedById String?
  moderatedAt   DateTime?    @db.Timestamptz(3)
  publishedAt   DateTime?    @db.Timestamptz(3)
  /// IP of the public submitter — kept for rate-limit / abuse forensics.
  submitterIp   String?
  /// External review ID (Booking/Airbnb) for import dedup.
  externalId    String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  property    Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  guest       Guest?       @relation(fields: [guestId], references: [id], onDelete: SetNull)
  moderatedBy User?        @relation("ReviewModeratedBy", fields: [moderatedById], references: [id], onDelete: SetNull)

  @@index([propertyId, status, publishedAt])
  @@index([status, createdAt])
  @@index([source, externalId])
}

// =============================================================================
// INTERNAL NOTES — admin-only annotations on a reservation or guest
// =============================================================================

model InternalNote {
  id            String   @id @default(cuid())
  /// Either reservationId OR guestId must be set (or both — a note on
  /// a guest stays visible across all their reservations too).
  reservationId String?
  guestId       String?
  authorId      String?
  body          String   @db.Text
  /// Optional category for filtering ("alerte", "préférence", "incident").
  category      String?
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)

  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  guest       Guest?       @relation(fields: [guestId], references: [id], onDelete: Cascade)
  author      User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([reservationId, createdAt])
  @@index([guestId, createdAt])
}

// =============================================================================
// GUEST DOCUMENTS — ID scans uploaded to Supabase Storage
// =============================================================================

enum GuestDocumentKind {
  ID_CARD
  PASSPORT
  DRIVING_LICENSE
  OTHER
}

model GuestDocument {
  id           String            @id @default(cuid())
  guestId      String
  kind         GuestDocumentKind @default(ID_CARD)
  /// Storage key within the private `guest-docs` Supabase bucket.
  /// Signed URLs are minted on-demand by lib/storage.
  storageKey   String
  mimeType     String
  /// Original filename uploaded by the staff (for display only).
  filename     String
  /// Bytes — surfaced in the admin UI.
  sizeBytes    Int
  /// Document number (passport #, ID #) typed by the receptionist.
  docNumber    String?
  /// Expiration date of the document (optional).
  expiresAt    DateTime?         @db.Date
  notes        String?
  uploadedById String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  guest      Guest @relation(fields: [guestId], references: [id], onDelete: Cascade)
  uploadedBy User? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([guestId, createdAt])
}

// =============================================================================
// PROMO CODES — promotional discounts applied in the funnel and admin wizard
// =============================================================================

enum PromoCodeKind {
  PERCENT // value = percent 0-100
  FIXED // value = millimes off
}

model PromoCode {
  id           String        @id @default(cuid())
  /// Uppercase code (e.g. "ETE2026") — unique across the catalog.
  code         String        @unique
  /// Optional human-friendly label for the admin list ("Soldes été 2026").
  label        String?
  kind         PromoCodeKind @default(PERCENT)
  /// For PERCENT: 0-100. For FIXED: millimes.
  value        Int
  /// Minimum stay (nights) before the code can be applied. 0 = no minimum.
  minNights    Int           @default(0)
  /// Restrict to a specific property type. Null = both.
  propertyType PropertyType?
  /// Total redemption cap. 0 = unlimited.
  maxUses      Int           @default(0)
  /// Counter incremented on each successful application.
  usedCount    Int           @default(0)
  /// Validity window — both inclusive.
  validFrom    DateTime?     @db.Date
  validTo      DateTime?     @db.Date
  active       Boolean       @default(true)
  createdById  String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  createdBy   User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)
  redemptions PromoRedemption[]

  @@index([active, validFrom, validTo])
}

/// One row per Reservation that consumed a PromoCode. Keeps audit clean
/// and lets us decrement `usedCount` safely on cancellation.
model PromoRedemption {
  id            String   @id @default(cuid())
  promoCodeId   String
  reservationId String   @unique
  /// Millimes actually discounted at the moment of application.
  amountApplied Int
  createdAt     DateTime @default(now()) @db.Timestamptz(3)

  promoCode   PromoCode   @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([promoCodeId, createdAt])
}

// =============================================================================
// PRICING SUPPLEMENTS — reusable admin catalog of extras (cleaning, padel, …)
// =============================================================================

model PricingSupplement {
  id            String  @id @default(cuid())
  /// Stable slug ("cleaning-final", "padel-session") for code-level refs.
  slug          String  @unique
  labelFr       String
  labelEn       String?
  labelAr       String?
  /// Default price in millimes. Receptionists can override per reservation.
  priceMillimes Int
  /// Free-form category for grouping in the picker ("Services", "Loisirs").
  category      String?
  /// Optional lucide icon name for the picker.
  icon          String?
  sortOrder     Int     @default(100)
  active        Boolean @default(true)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([active, sortOrder])
}
