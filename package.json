    "db:seed": "prisma db seed",
    "db:seed:photos": "dotenv -e .env.local -- tsx scripts/seed-photos.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "postinstall": "prisma generate --no-hints",
    "prepare": "husky"
  },
